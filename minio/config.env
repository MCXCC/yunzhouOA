# MinIO Configuration File
# ========================

# MinIO访问密钥和秘密密钥
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# 数据存储目录（相对于minio目录）
MINIO_DATA_DIR=./data

# 服务地址配置
MINIO_ADDRESS=:9000
MINIO_BROWSER_ADDRESS=:9001

# 如果需要启用HTTPS，设置以下选项
# MINIO_CERTS_DIR=./certs

# 其他配置选项
# MINIO_BROWSER=on
# MINIO_DOMAIN=